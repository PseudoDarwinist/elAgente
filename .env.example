# ========= LLM (choose one provider) =========
# Provider options: gemini | anthropic | self-hosted | mock
PROVIDER=self-hosted
# Self-hosted OpenAI-compatible endpoint
LLM_API_URL=https://quasarmarket.coforge.com/qag/llmrouter-api/v2/chat/completions
LLM_API_KEY=your-llm-api-key
MODEL=claude-sonnet-4
# For Gemini (fallback)
GEMINI_API_KEY=
# Max tokens for responses (LLM server)
MAX_TOKENS=4000

# ========= Slack (optional but recommended) =========
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_TEAM_ID=T095W5T02R0
SLACK_SIGNING_SECRET=your-slack-signing-secret
# Channel to post the final summary (must be channel ID like C01234567)
SLACK_CHANNEL_ID=C095S2NQQMV

# ========= GitHub =========
# Token should have repo scope (or public_repo for public repos)
GITHUB_PERSONAL_ACCESS_TOKEN=github_pat_your-token-here
# Context for prompt-server navigation
GITHUB_ORGANISATION=PseudoDarwinist
GITHUB_REPO_NAME=elAgente
# Path within the repo where your app code lives ("." for root)
PROJECT_ROOT=.

# ========= Orchestrator / Agent =========
# Bearer token for calling /diagnose locally via curl
DEV_BEARER_TOKEN=dev-token-123
# Query timeout in seconds
QUERY_TIMEOUT=300
# Enable only non-K8s servers for local run
ENABLED_SERVERS=["slack","github","loki-mcp"]
# Allowed tools (limited set to avoid large payload)
TOOLS=["query_logs_by_service","get_error_logs","get_available_services","slack_post_message","get_file_contents","create_issue"]
# List of service names you want to diagnose (space of one is fine)
SERVICES=["promptbuilder", "payment-service", "aura-backend", "aura-frontend"]

# ========= Firewall (optional) =========
# Hugging Face token if required by your environment (can be left empty)
HF_TOKEN=


# Alert webhook settings
ALERT_WEBHOOK_SECRET=
ALERT_COOLDOWN_SECONDS=600
QDRANT_URL=http://qdrant:6333


QDRANT_URL=http://qdrant:6333
ENABLED_SERVERS=["slack","github","loki-mcp","prompt-server"]
SERVICES=["aura-backend"]
TOOLS=[]

# Agent worker (Claude SDK) configuration
USE_AGENT_WORKER=true
AGENT_WORKER_URL=http://host.docker.internal:3005
LOKI_MCP_URL=http://loki-mcp:3001/sse
SLACK_MCP_URL=http://slack:3001/sse
GITHUB_MCP_URL=http://github:3001/sse

# Optional
# HF_TOKEN=your-hf-token
# FIREWALL_ENABLED=false
