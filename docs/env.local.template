# ========= LLM (choose one provider) =========
# Provider options: gemini | anthropic
PROVIDER=gemini
# For Gemini: recommended free-tier model
MODEL=gemini-1.5-flash
GEMINI_API_KEY=
# For Anthropic (optional if using Gemini)
ANTHROPIC_API_KEY=
# Max tokens for responses (LLM server)
MAX_TOKENS=1000

# ========= Slack (optional but recommended) =========
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=
SLACK_SIGNING_SECRET=
# Channel to post the final summary (must be channel ID like C01234567)
SLACK_CHANNEL_ID=

# ========= GitHub =========
# Token should have repo scope (or public_repo for public repos)
GITHUB_PERSONAL_ACCESS_TOKEN=
# Context for prompt-server navigation
GITHUB_ORGANISATION=
GITHUB_REPO_NAME=
# Path within the repo where your app code lives ("." for root)
PROJECT_ROOT=.

# ========= Orchestrator / Agent =========
# Bearer token for calling /diagnose locally via curl
DEV_BEARER_TOKEN=dev-token-123
# Query timeout in seconds
QUERY_TIMEOUT=300
# Enable only non-K8s servers for local run
ENABLED_SERVERS=["slack","github","prompt-server"]
# Allowed tools (minimum viable set)
TOOLS=["get_file_contents","create_issue","slack_post_message","slack_list_channels"]
# List of service names you want to diagnose (space of one is fine)
SERVICES=["salesforce"]

# ========= Firewall (optional) =========
# Hugging Face token if required by your environment (can be left empty)
HF_TOKEN=







