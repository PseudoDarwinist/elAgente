# Demo Environment Configuration
# Copy this file to .env and fill in your values

# === Required ===
DEV_BEARER_TOKEN=your-bearer-token-here
GEMINI_API_KEY=your-gemini-api-key

# === LLM Configuration ===
PROVIDER=gemini
MODEL=gemini-2.0-flash

# === GitHub Configuration ===
GITHUB_PERSONAL_ACCESS_TOKEN=your-github-pat
GITHUB_ORGANISATION=your-org
GITHUB_REPO_NAME=your-repo
PROJECT_ROOT=src

# === Slack Configuration ===
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_TEAM_ID=T00000000
SLACK_CHANNEL_ID=C00000000
SLACK_SIGNING_SECRET=your-signing-secret

# === Alert Configuration ===
ALERT_WEBHOOK_SECRET=your-webhook-secret
ALERT_COOLDOWN_SECONDS=60

# === RAG Configuration ===
QDRANT_URL=http://qdrant:6333
GEMINI_EMBED_MODEL=text-embedding-004

# === MCP Servers to Enable ===
# Options: slack, github, loki-mcp, prompt-server
ENABLED_SERVERS=["slack", "github", "loki-mcp", "prompt-server"]

# === Services to Monitor ===
SERVICES=["payment-service"]

# === Tools Available ===
TOOLS=[]

# === Optional ===
# HF_TOKEN=your-huggingface-token  # For Llama Firewall
# FIREWALL_ENABLED=false
